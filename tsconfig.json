{
  "include": [
    "src"
  ],
  "exclude": [
    "**/*.test.ts"
  ],
  "compilerOptions": {
    "module": "node16",
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "declaration": true,
    "strict": true,
    "moduleResolution": "node16",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": true,
    "types": [
      "node"
    ],
    "forceConsistentCasingInFileNames": true
  }
}